{
  "manifest_version": 3,
  "name": "mybuilding — Upwork Assistant",
  "version": "1.1",
  "description": "Personal Upwork productivity assistant — manual job scanning, cover letter helper, CRM integration",
  "permissions": [
    "tabs",
    "storage",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "https://www.upwork.com/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.upwork.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mybuilding.dev/*", "http://localhost:*/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
